# Copy to ".env" and adjust if needed.
# Never commit ".env" with production secrets.

ENVIRONMENT=development

APP_NAME=DeliveryPulse AI API

# New database only — do not point at existing DBs you rely on elsewhere.
DATABASE_URL=postgresql+psycopg2://postgres:root@127.0.0.1:5432/deliverypulse_ai

JWT_SECRET=change-me-to-a-long-random-string-for-dev-only
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
